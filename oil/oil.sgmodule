[Panel]
油价查询=title="油价查询",content="点击刷新加载油价",style=info,script-name=oilPrice
[Script]
oilPrice=type=generic,script-path=https://raw.githubusercontent.com/YcccByHe/SurgeModelPanel/main/oil/oil.js,argument=ApiKey={{{[API]天行Key}}}&Province={{{[地区]省份}}}&Icon={{{[图标]名称}}}&Color={{{[颜色]色值}}}
